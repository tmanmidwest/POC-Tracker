# Demo instance, alongside prod on the same docker host — copy to demo.env and adjust.
#   docker compose --env-file demo.env up -d --build
#
# A distinct POCT_STACK_NAME namespaces the compose project, containers, network, and
# poct-data volume (so demo shares no database/tokens/keys with prod). A distinct
# POCT_IMAGE tag means rebuilding demo builds its own image and never clobbers the
# tag prod runs. Non-colliding host ports keep both reachable at once.

POCT_STACK_NAME=poc-tracker-demo
POCT_IMAGE=poc-tracker:demo
POCT_HOST_PORT=9010
POCT_MCP_HOST_PORT=9011
POCT_ENABLE_DEMO_TOOLS=1   # expose the admin Settings → Demo Data page on this instance
