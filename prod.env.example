# Production instance — copy to prod.env and adjust.
#   docker compose --env-file prod.env up -d --build
#
# These are the defaults, so a bare `docker compose up -d --build` (no --env-file)
# behaves the same. Set them explicitly here to make the prod/demo split obvious
# and to pin prod to its own image tag so a demo rebuild can't overwrite it.

POCT_STACK_NAME=poc-tracker
POCT_IMAGE=poc-tracker:prod
POCT_HOST_PORT=8010
POCT_MCP_HOST_PORT=8011
# POCT_ENABLE_DEMO_TOOLS stays unset on production.
